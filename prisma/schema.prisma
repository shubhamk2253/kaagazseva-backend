generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  DIRECT_DATABASE_URL= env("postgresql://postgres:kaagaz%402253@db.lnxpuaqvjgqxghszuhwl.supabase.co:5432/postgres"")
}

///////////////////////////////////////////////////////
// ENUMS
///////////////////////////////////////////////////////

enum UserRole {
  CUSTOMER
  AGENT
  DISTRICT_ADMIN
  STATE_ADMIN
  FOUNDER
}

enum ApplicationStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  ASSIGNING
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  DOCS_COLLECTED
  SUBMITTED
  GOVT_PROCESSING
  COMPLETED
  CONFIRMED
  CLOSED
  REASSIGNING
  ON_HOLD
  DISPUTED
  REFUND_PENDING
  REFUNDED
  REJECTED
  CANCELLED
}

enum AssignmentStatus {
  PENDING
  ACCEPTED
  REJECTED
  TIMEOUT
  CANCELLED
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum TransactionType {
  CREDIT
  DEBIT
  ESCROW_HOLD
  ESCROW_RELEASE
  REFUND
}

enum ServiceMode {
  DIGITAL
  DOORSTEP
  FULL_COMPLETION
}

enum ServiceScope {
  NATIONAL
  STATE
  DISTRICT
}

enum DocumentStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum SuspensionStatus {
  NONE
  UNDER_REVIEW
  CONFIRMED
  REJECTED
  ESCALATED
  AUTO_ESCALATED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  FAILED
}

enum NotificationType {
  APPLICATION_UPDATE
  PAYMENT_UPDATE
  AGENT_ASSIGNMENT
  SYSTEM_ALERT
  ESCALATION_UPDATE
  GENERAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  PAYMENT_ISSUE
  DOCUMENT_REJECTION
  AGENT_MISCONDUCT
  SERVICE_DELAY
  TECHNICAL_GLITCH
  GENERAL_QUERY
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  LOGIN
  LOGOUT
  PAYMENT
  ACCESS
  ASSIGNMENT
  PAYOUT
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSED
}

enum KycStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

///////////////////////////////////////////////////////
// GEOGRAPHY
///////////////////////////////////////////////////////

model State {
  id       String  @id @default(uuid())
  name     String
  code     String  @unique // MH, UP, RJ etc.
  capital  String?
  isUt     Boolean @default(false) // Union Territory flag
  isActive Boolean @default(true)

  districts    District[]
  services     Service[]
  pincodes     Pincode[]
  users        User[]
  applications Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

model District {
  id   String @id @default(uuid())
  name String

  stateId String
  state   State  @relation(fields: [stateId], references: [id], onDelete: Cascade)

  // Centroid coordinates for radius-based fallback assignment
  latitude  Float?
  longitude Float?

  isActive Boolean @default(true)

  pincodes     Pincode[]
  users        User[]
  applications Application[]

  createdAt DateTime @default(now())

  @@unique([name, stateId])
  @@index([stateId])
}

model Pincode {
  id   String @id @default(uuid())
  code String @unique

  districtId String
  district   District @relation(fields: [districtId], references: [id], onDelete: Cascade)

  stateId String
  state   State  @relation(fields: [stateId], references: [id], onDelete: Cascade)

  officeName String?
  officeType String? // HO, SO, BO
  latitude   Float?
  longitude  Float?
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([code])
  @@index([districtId])
  @@index([stateId])
}

///////////////////////////////////////////////////////
// USER & PROFILE
///////////////////////////////////////////////////////

model User {
  id          String   @id @default(uuid())
  phoneNumber String?  @unique
  email       String?  @unique
  password    String? // hashed
  name        String?
  role        UserRole @default(CUSTOMER)
  isActive    Boolean  @default(true)
  isOnline    Boolean  @default(false)
  fcmToken    String? // Firebase push notification token

  // Geography relations (proper FK, not plain strings)
  stateId    String?
  state      State?    @relation(fields: [stateId], references: [id])
  districtId String?
  district   District? @relation(fields: [districtId], references: [id])

  // Suspension
  suspensionStatus         SuspensionStatus @default(NONE)
  isSuspended              Boolean          @default(false)
  suspensionReviewDeadline DateTime?
  suspensionLevel          Int              @default(0)
  suspensionReason         String?
  suspendedBy              String?
  suspendedAt              DateTime?

  // Relations
  agentProfile AgentProfile?
  wallet       Wallet?

  applications     Application[]           @relation("CustomerApplications")
  assignedApps     Application[]           @relation("AgentApplications")
  appAssignments   ApplicationAssignment[]
  agentServices    AgentService[]
  transactions     Transaction[]
  escrowAsCustomer EscrowHolding[]         @relation("EscrowCustomer")
  escrowAsAgent    EscrowHolding[]         @relation("EscrowAgent")

  withdrawals         WithdrawalRequest[] @relation("AgentWithdrawals")
  approvedWithdrawals WithdrawalRequest[] @relation("ApprovedWithdrawals")
  rejectedWithdrawals WithdrawalRequest[] @relation("RejectedWithdrawals")

  agentMetrics  AgentMetrics?
  agentPayouts  AgentPayout[]
  notifications Notification[]

  ticketsCreated  Ticket[]         @relation("CreatedTickets")
  ticketsAssigned Ticket[]         @relation("AssignedTickets")
  ticketResponses TicketResponse[]

  auditLogs AuditLog[]

  initiatedSuspensions SuspensionCase[] @relation("SuspensionInitiator")
  suspensionCases      SuspensionCase[] @relation("UserSuspensions")
  escalatedCases       SuspensionCase[] @relation("EscalatedTo")
  resolvedCases        SuspensionCase[] @relation("ResolvedBy")

  refundRequests  RefundRequest[] @relation("RefundRequester")
  reviewedRefunds RefundRequest[] @relation("RefundReviewer")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([stateId])
  @@index([districtId])
  @@index([isActive, role])
  @@index([isSuspended])
  @@index([email])
  @@index([phoneNumber])
}

///////////////////////////////////////////////////////
// AGENT PROFILE
// Separated from User to keep User model clean
// Only exists for users with role = AGENT
///////////////////////////////////////////////////////

model AgentProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // KYC verification
  kycStatus       KycStatus @default(PENDING)
  aadhaarVerified Boolean   @default(false)
  panVerified     Boolean   @default(false)
  policeVerified  Boolean   @default(false)
  kycDocumentUrl  String?
  kycVerifiedAt   DateTime?
  kycVerifiedBy   String?

  // Live location (updated by agent app in realtime)
  latitude        Float?
  longitude       Float?
  lastLocationAt  DateTime?
  serviceRadiusKm Int       @default(25)

  // Availability
  isAvailable   Boolean   @default(true)
  availableFrom DateTime?
  availableTo   DateTime?

  // Razorpay payout account
  razorpayContactId     String?
  razorpayFundAccountId String?
  bankVerified          Boolean @default(false)
  bankAccountNumber     String?
  bankIfsc              String?
  bankAccountName       String?

  // Onboarding
  onboardingComplete Boolean   @default(false)
  probationEndsAt    DateTime? // first 10 jobs in probation
  depositAmount      Decimal?  @db.Decimal(12, 2) // refundable bond

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isAvailable])
  @@index([latitude, longitude])
  @@index([kycStatus])
}

///////////////////////////////////////////////////////
// FINANCIALS
///////////////////////////////////////////////////////

model Wallet {
  id       String  @id @default(uuid())
  balance  Decimal @default(0.0) @db.Decimal(12, 2)
  isFrozen Boolean @default(false)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  withdrawals  WithdrawalRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id             String   @id @default(uuid())
  idempotencyKey String?  @unique // prevents duplicate transactions
  amount         Decimal  @db.Decimal(12, 2)
  balanceBefore  Decimal? @db.Decimal(12, 2)
  balanceAfter   Decimal? @db.Decimal(12, 2)

  type   TransactionType
  status TransactionStatus @default(PENDING)

  gatewayOrderId   String?
  gatewayPaymentId String?
  referenceId      String?
  metadata         Json?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  walletId String?
  wallet   Wallet? @relation(fields: [walletId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([referenceId])
  @@index([walletId])
  @@index([createdAt])
  @@index([type, status])
}

model EscrowHolding {
  id            String      @id @default(uuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  customerId String
  customer   User   @relation("EscrowCustomer", fields: [customerId], references: [id], onDelete: Cascade)

  agentId String?
  agent   User?   @relation("EscrowAgent", fields: [agentId], references: [id])

  totalAmount    Decimal @db.Decimal(12, 2)
  platformAmount Decimal @db.Decimal(12, 2)
  agentAmount    Decimal @db.Decimal(12, 2)
  deliveryAmount Decimal @default(0) @db.Decimal(12, 2)

  isReleased  Boolean   @default(false)
  releasedAt  DateTime?
  releaseNote String?

  // Razorpay transfer reference
  transferId String?

  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([isReleased])
  @@index([agentId])
}

model AgentPayout {
  id      String @id @default(uuid())
  agentId String
  agent   User   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  applicationId String
  amount        Decimal      @db.Decimal(12, 2)
  status        PayoutStatus @default(PENDING)

  // Razorpay payout reference
  razorpayPayoutId      String?
  razorpayTransferId    String?
  razorpayFundAccountId String?

  processedAt   DateTime?
  failureReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@index([status])
  @@index([applicationId])
}

model WithdrawalRequest {
  id       String           @id @default(uuid())
  agentId  String
  walletId String
  amount   Decimal          @db.Decimal(12, 2)
  status   WithdrawalStatus

  approvedBy      String?
  rejectedBy      String?
  rejectionReason String?

  approvedAt  DateTime?
  rejectedAt  DateTime?
  processedAt DateTime?

  // Razorpay payout reference
  razorpayPayoutId String?

  createdAt DateTime @default(now())

  agent    User   @relation("AgentWithdrawals", fields: [agentId], references: [id], onDelete: Cascade)
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  approver User?  @relation("ApprovedWithdrawals", fields: [approvedBy], references: [id])
  rejector User?  @relation("RejectedWithdrawals", fields: [rejectedBy], references: [id])

  @@index([agentId])
  @@index([status])
  @@index([createdAt])
}

///////////////////////////////////////////////////////
// APPLICATION & ASSIGNMENT
///////////////////////////////////////////////////////

model Application {
  id              String @id @default(uuid())
  referenceNumber String @unique // KS-2024-000001

  // Geography — proper relations not plain strings
  stateId    String
  state      State    @relation(fields: [stateId], references: [id])
  districtId String
  district   District @relation(fields: [districtId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  mode   ServiceMode
  status ApplicationStatus @default(DRAFT)

  // Pricing snapshot — immutable after payment
  // Structure: { govtFee, multiplier, serviceFee, deliveryFee,
  //              totalAmount, distanceKm, calculatedAt, pricingRuleId }
  pricingSnapshot Json?

  govtFee            Decimal @db.Decimal(12, 2)
  serviceFee         Decimal @db.Decimal(12, 2)
  platformCommission Decimal @db.Decimal(12, 2)
  agentCommission    Decimal @db.Decimal(12, 2)
  deliveryFee        Decimal @default(0.0) @db.Decimal(12, 2)
  totalAmount        Decimal @db.Decimal(12, 2)

  // Distance snapshot — immutable, prevents manipulation
  distanceKm Float?

  // Payment
  paymentStatus     TransactionStatus @default(PENDING)
  paidAt            DateTime?
  razorpayOrderId   String?
  razorpayPaymentId String?

  // Customer location snapshot
  customerLat     Float?
  customerLng     Float?
  deliveryAddress String?
  customerPincode String?

  // Assignment
  assignmentDeadline     DateTime?
  assignedAt             DateTime?
  acceptedAt             DateTime?
  assignmentAttemptCount Int       @default(0)

  // Completion
  completedAt         DateTime?
  confirmedAt         DateTime?
  closedAt            DateTime?
  completionProofUrl  String?
  govtAckReceiptUrl   String?
  customerOtpVerified Boolean   @default(false)

  // Risk & escalation
  riskScore       Int     @default(0)
  manualReview    Boolean @default(false)
  escalationLevel Int     @default(0)

  // Refund
  refundRequested Boolean @default(false)

  // Ratings
  customerRating Int? // 1-5
  agentRating    Int? // 1-5
  customerReview String?
  agentReview    String?

  // Relations
  customerId String
  customer   User   @relation("CustomerApplications", fields: [customerId], references: [id], onDelete: Cascade)

  agentId String?
  agent   User?   @relation("AgentApplications", fields: [agentId], references: [id])

  documents   ApplicationDocument[]
  escrow      EscrowHolding?
  refunds     RefundRequest[]
  history     ApplicationLog[]
  timeline    ApplicationTimeline?
  assignments ApplicationAssignment[]
  tickets     Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([agentId])
  @@index([status])
  @@index([serviceId])
  @@index([stateId])
  @@index([districtId])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([customerId, status])
  @@index([referenceNumber])
}

model ApplicationTimeline {
  id            String      @id @default(uuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // Timestamps for each milestone
  // Null = not reached yet
  paidAt           DateTime?
  assigningAt      DateTime?
  assignedAt       DateTime?
  acceptedAt       DateTime?
  inProgressAt     DateTime?
  docsCollectedAt  DateTime?
  submittedAt      DateTime?
  govtProcessingAt DateTime?
  completedAt      DateTime?
  confirmedAt      DateTime?
  closedAt         DateTime?
  disputedAt       DateTime?
  refundedAt       DateTime?
  cancelledAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApplicationAssignment {
  id String @id @default(uuid())

  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  agentId String
  agent   User   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  status AssignmentStatus @default(PENDING)

  assignedAt  DateTime  @default(now())
  respondedAt DateTime?
  deadlineAt  DateTime? // 60 min acceptance deadline

  responseReason String?
  priorityScore  Float?

  // Assignment metadata
  districtMatch Boolean @default(false) // was agent in same district?
  attemptNumber Int     @default(1)

  createdAt DateTime @default(now())

  @@unique([applicationId, agentId])
  @@index([applicationId])
  @@index([agentId])
  @@index([status])
  @@index([status, assignedAt]) // for timeout detection queries
}

model ApplicationDocument {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  name     String
  fileUrl  String
  fileSize Int? // bytes
  mimeType String?
  status   DocumentStatus @default(PENDING)
  feedback String?
  version  Int            @default(1) // document versioning

  // Watermark metadata
  watermarked   Boolean @default(false)
  watermarkData String? // agent_id + timestamp encoded

  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([applicationId])
}

model ApplicationLog {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  fromStatus    ApplicationStatus
  toStatus      ApplicationStatus
  note          String?
  updatedBy     String?
  updatedByRole UserRole?

  createdAt DateTime @default(now())

  @@index([applicationId])
  @@index([createdAt])
}

///////////////////////////////////////////////////////
// SERVICES & PRICING
///////////////////////////////////////////////////////

model Service {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  description String?
  scope       ServiceScope @default(NATIONAL)
  isActive    Boolean      @default(true)

  // Null = national service (available in all states)
  stateId String?
  state   State?  @relation(fields: [stateId], references: [id], onDelete: Cascade)

  // Available modes for this service
  availableModes ServiceMode[]

  estimatedDays Int? // typical completion time

  pricingRules      PricingRule[]
  requiredDocuments ServiceRequiredDocument[]
  applications      Application[]
  agentCapabilities AgentService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope])
  @@index([stateId])
  @@index([isActive])
}

model AgentService {
  id         String    @id @default(uuid())
  agentId    String
  agent      User      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  serviceId  String
  service    Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  isActive   Boolean   @default(true)
  verifiedAt DateTime?

  @@unique([agentId, serviceId])
  @@index([agentId])
  @@index([serviceId])
}

model PricingRule {
  id        String  @id @default(uuid())
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  mode       ServiceMode
  minGovtFee Decimal     @db.Decimal(12, 2)
  maxGovtFee Decimal     @db.Decimal(12, 2)
  multiplier Float

  // Override fields — if set, use these directly
  fixedServiceFee    Decimal? @db.Decimal(12, 2)
  platformCommission Decimal? @db.Decimal(12, 2)
  agentCommission    Decimal? @db.Decimal(12, 2)

  // Delivery pricing
  deliveryBaseFee Decimal? @db.Decimal(12, 2) // default ₹30
  deliveryPerKm   Decimal? @db.Decimal(12, 2) // default ₹12
  maxRadiusKm     Float? // default 25km

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceId])
  @@index([mode])
}

model ServiceRequiredDocument {
  id           String  @id @default(uuid())
  documentName String
  description  String?
  isMandatory  Boolean @default(true)
  order        Int     @default(0)

  // State-specific document requirements
  // Null = required in all states
  stateId String?

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([serviceId])
}

///////////////////////////////////////////////////////
// METRICS & PERFORMANCE
///////////////////////////////////////////////////////

model AgentMetrics {
  id      String @id @default(uuid())
  agentId String @unique
  agent   User   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  // Workload
  activeCases    Int @default(0)
  completedCases Int @default(0)

  // Performance
  rejectionCount     Int    @default(0)
  timeoutCount       Int    @default(0)
  avgCompletionHours Float? // average time to complete
  completionRate     Float  @default(1.0) // completed/assigned

  // Quality
  rating       Float @default(5.0)
  ratingCount  Int   @default(0)
  penaltyCount Int   @default(0)

  // Computed priority score for assignment engine
  // Lower = better (assigned first)
  priorityScore Float @default(0)

  // Financial
  totalEarnings Decimal @default(0) @db.Decimal(12, 2)
  pendingPayout Decimal @default(0) @db.Decimal(12, 2)

  updatedAt DateTime @updatedAt

  @@index([priorityScore])
  @@index([activeCases])
  @@index([rating])
}

///////////////////////////////////////////////////////
// REFUNDS
///////////////////////////////////////////////////////

model RefundRequest {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  requestedById String
  requestedBy   User   @relation("RefundRequester", fields: [requestedById], references: [id])

  reviewedById String?
  reviewedBy   User?   @relation("RefundReviewer", fields: [reviewedById], references: [id])

  amount   Decimal      @db.Decimal(12, 2)
  reason   String
  evidence String? // URL to supporting document/screenshot
  status   RefundStatus @default(REQUESTED)

  // Razorpay refund reference
  razorpayRefundId String?

  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([applicationId])
  @@index([status])
  @@index([requestedById])
}

///////////////////////////////////////////////////////
// SUPPORT & TICKETS
///////////////////////////////////////////////////////

model Ticket {
  id          String         @id @default(uuid())
  title       String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  category    TicketCategory

  // Optional link to application
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id])

  createdById String
  createdBy   User   @relation("CreatedTickets", fields: [createdById], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?   @relation("AssignedTickets", fields: [assignedToId], references: [id])

  resolvedAt DateTime?
  closedAt   DateTime?

  responses TicketResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
  @@index([status])
  @@index([priority])
  @@index([applicationId])
}

model TicketResponse {
  id         String  @id @default(uuid())
  ticketId   String
  ticket     Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message    String
  isInternal Boolean @default(false) // internal staff notes

  createdAt DateTime @default(now())

  @@index([ticketId])
}

///////////////////////////////////////////////////////
// SUSPENSION & COMPLIANCE
///////////////////////////////////////////////////////

model SuspensionCase {
  id     String @id @default(uuid())
  userId String
  user   User   @relation("UserSuspensions", fields: [userId], references: [id], onDelete: Cascade)

  initiatedById String
  initiatedBy   User   @relation("SuspensionInitiator", fields: [initiatedById], references: [id])

  status SuspensionStatus
  level  Int              @default(0)

  reason   String
  evidence Json?

  appealAt       DateTime?
  appealMessage  String?
  appealDeadline DateTime?

  escalatedToId String?
  escalatedTo   User?   @relation("EscalatedTo", fields: [escalatedToId], references: [id])

  resolvedById   String?
  resolvedBy     User?     @relation("ResolvedBy", fields: [resolvedById], references: [id])
  resolvedAt     DateTime?
  resolutionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

///////////////////////////////////////////////////////
// NOTIFICATIONS
///////////////////////////////////////////////////////

model Notification {
  id      String           @id @default(uuid())
  userId  String
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type    NotificationType
  title   String
  message String
  isRead  Boolean          @default(false)

  // Deep link data
  actionUrl String?
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([userId, isRead]) // unread notifications query
  @@index([userId])
  @@index([createdAt])
}

///////////////////////////////////////////////////////
// SYSTEM & AUDIT
///////////////////////////////////////////////////////

model AuditLog {
  id     String  @id @default(uuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action       AuditAction
  resourceType String
  resourceId   String?

  method     String?
  path       String?
  oldData    Json?
  newData    Json?
  ip         String?
  userAgent  String?
  requestId  String?
  statusCode Int?
  success    Boolean? @default(true)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([action])
  @@index([createdAt])
}

model PaymentWebhookEvent {
  id           String    @id @default(uuid())
  eventId      String    @unique // Razorpay event ID — prevents duplicate processing
  eventType    String
  payload      Json
  processed    Boolean   @default(false)
  processedAt  DateTime?
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([processed])
  @@index([eventType])
}

model SystemControl {
  id                String  @id @default(uuid())
  paymentsFrozen    Boolean @default(false)
  withdrawalsFrozen Boolean @default(false)
  refundsFrozen     Boolean @default(false)
  assignmentsPaused Boolean @default(false) // NEW — pause all assignments
  maintenanceMode   Boolean @default(false) // NEW — full platform pause

  updatedAt  DateTime @updatedAt
  updatedBy  String? // who flipped the switch
  updateNote String? // why it was changed
}

model AppConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  // Stores runtime config like:
  // max_agent_active_cases = 25
  // max_service_radius_km = 25
  // agent_acceptance_timeout_mins = 60
  // min_service_fee = 99
  // max_service_fee = 800
  // delivery_base_fee = 30
  // delivery_per_km = 12
}
