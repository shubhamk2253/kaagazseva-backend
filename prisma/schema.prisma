generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

///////////////////////////////////////////////////////
// ENUMS
///////////////////////////////////////////////////////

enum UserRole {
  CUSTOMER
  AGENT
  ADMIN
}

enum ApplicationStatus {
  DRAFT
  PENDING_PAYMENT
  SUBMITTED
  ASSIGNED
  UNDER_REVIEW
  DOCUMENT_REQUIRED
  COMPLETED
  REJECTED
  CANCELLED
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum TransactionType {
  CREDIT
  DEBIT
  ESCROW_HOLD
  ESCROW_RELEASE
  REFUND
}

enum ServiceMode {
  DIGITAL
  DOORSTEP
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  FAILED
}

///////////////////////////////////////////////////////
// 🔔 NOTIFICATION SYSTEM (RESTORED CLEANLY)
///////////////////////////////////////////////////////

enum NotificationType {
  APPLICATION_UPDATE
  PAYMENT_UPDATE
  SYSTEM_ALERT
  GENERAL
}

///////////////////////////////////////////////////////
// USER
///////////////////////////////////////////////////////

model User {
  id          String   @id @default(uuid())
  phoneNumber String   @unique
  name        String?
  role        UserRole @default(CUSTOMER)
  isActive    Boolean  @default(true)

  // 🌍 Geo + Assignment Info
  state     String?
  district  String?
  latitude  Float?
  longitude Float?

  wallet Wallet?

  // Applications
  applications Application[] @relation("CustomerApplications")
  assignedApps Application[] @relation("AgentApplications")

  // Financial
  transactions Transaction[]

  escrowAsCustomer EscrowHolding[] @relation("EscrowCustomer")
  escrowAsAgent    EscrowHolding[] @relation("EscrowAgent")

  withdrawals Withdrawal[]

  // Performance
  agentMetrics AgentMetrics?

  // Notifications
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([isActive])
  @@index([state])
  @@index([district])
  @@index([createdAt])
}

///////////////////////////////////////////////////////
// WALLET
///////////////////////////////////////////////////////

model Wallet {
  id      String  @id @default(uuid())
  balance Decimal @default(0.0) @db.Decimal(12, 2)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

///////////////////////////////////////////////////////
// APPLICATION
///////////////////////////////////////////////////////

model Application {
  id String @id @default(uuid())

  state       String
  district    String
  serviceType String
  mode        ServiceMode
  status      ApplicationStatus @default(DRAFT)

  documents Json

  govtFee            Decimal @db.Decimal(12, 2)
  serviceFee         Decimal @db.Decimal(12, 2)
  platformCommission Decimal @db.Decimal(12, 2)
  agentCommission    Decimal @db.Decimal(12, 2)
  deliveryFee        Decimal @default(0.0) @db.Decimal(12, 2)
  totalAmount        Decimal @db.Decimal(12, 2)

  distanceKm      Float?
  pricingSnapshot Json?

  paymentStatus TransactionStatus @default(PENDING)
  paidAt        DateTime?

  escrow EscrowHolding?

  customerId String
  customer   User   @relation("CustomerApplications", fields: [customerId], references: [id], onDelete: Cascade)

  agentId String?
  agent   User?   @relation("AgentApplications", fields: [agentId], references: [id])

  assignmentDeadline DateTime?
  assignedAt         DateTime?
  acceptedAt         DateTime?

  deliveryAddress String?
  customerLat     Float?
  customerLng     Float?

  completedAt   DateTime?
  autoReleaseAt DateTime?

  riskScore       Int     @default(0)
  manualReview    Boolean @default(false)
  refundRequested Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([agentId])
  @@index([status])
  @@index([state])
  @@index([district])
  @@index([assignmentDeadline])
  @@index([paymentStatus])
  @@index([riskScore])
}

///////////////////////////////////////////////////////
// ESCROW HOLDING
///////////////////////////////////////////////////////

model EscrowHolding {
  id String @id @default(uuid())

  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  customerId String
  customer   User   @relation("EscrowCustomer", fields: [customerId], references: [id], onDelete: Cascade)

  agentId String?
  agent   User?   @relation("EscrowAgent", fields: [agentId], references: [id])

  totalAmount    Decimal @db.Decimal(12, 2)
  platformAmount Decimal @db.Decimal(12, 2)
  agentAmount    Decimal @db.Decimal(12, 2)

  isReleased Boolean   @default(false)
  releasedAt DateTime?

  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([agentId])
  @@index([isReleased])
}

///////////////////////////////////////////////////////
// TRANSACTION
///////////////////////////////////////////////////////

model Transaction {
  id     String            @id @default(uuid())
  amount Decimal           @db.Decimal(12, 2)
  type   TransactionType
  status TransactionStatus @default(PENDING)

  gatewayOrderId   String?
  gatewayPaymentId String?

  referenceId String?
  metadata    Json?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([gatewayOrderId])
  @@index([createdAt])
}

///////////////////////////////////////////////////////
// AGENT METRICS
///////////////////////////////////////////////////////

model AgentMetrics {
  id String @id @default(uuid())

  agentId String @unique
  agent   User   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  activeCases    Int @default(0)
  completedCases Int @default(0)

  rating         Float @default(5.0)
  rejectionCount Int   @default(0)
  timeoutCount   Int   @default(0)

  priorityScore Float @default(0)

  updatedAt DateTime @updatedAt
}

///////////////////////////////////////////////////////
// WITHDRAWAL
///////////////////////////////////////////////////////

model Withdrawal {
  id String @id @default(uuid())

  agentId String
  agent   User   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  amount Decimal          @db.Decimal(12, 2)
  status WithdrawalStatus @default(PENDING)

  processedBy   String?
  processedAt   DateTime?
  failureReason String?

  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([status])
  @@index([createdAt])
}

///////////////////////////////////////////////////////
// NOTIFICATION
///////////////////////////////////////////////////////

model Notification {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  message String

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}