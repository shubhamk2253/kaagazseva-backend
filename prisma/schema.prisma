generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

///////////////////////////////////////////////////////
// ENUMS
///////////////////////////////////////////////////////

enum UserRole {
  CUSTOMER
  AGENT
  DISTRICT_ADMIN
  STATE_ADMIN
  FOUNDER
}

enum ApplicationStatus {
  DRAFT
  PENDING_PAYMENT
  SUBMITTED
  ASSIGNED
  UNDER_REVIEW
  DOCUMENT_REQUIRED
  COMPLETED
  REJECTED
  CANCELLED
}

enum AssignmentStatus {
  PENDING
  ACCEPTED
  REJECTED
  TIMEOUT
  CANCELLED
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum TransactionType {
  CREDIT
  DEBIT
  ESCROW_HOLD
  ESCROW_RELEASE
  REFUND
}

enum ServiceMode {
  DIGITAL
  DOORSTEP
}

enum DocumentStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum SuspensionStatus {
  NONE
  UNDER_REVIEW
  CONFIRMED
  REJECTED
  ESCALATED
  AUTO_ESCALATED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  FAILED
}

enum NotificationType {
  APPLICATION_UPDATE
  PAYMENT_UPDATE
  SYSTEM_ALERT
  GENERAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  PAYMENT_ISSUE
  DOCUMENT_REJECTION
  TECHNICAL_GLITCH
  GENERAL_QUERY
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  LOGIN
  LOGOUT
  PAYMENT
  ACCESS
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSED
}

///////////////////////////////////////////////////////
// USER & PROFILE
///////////////////////////////////////////////////////

model User {
  id          String   @id @default(uuid())
  phoneNumber String   @unique
  name        String?
  role        UserRole @default(CUSTOMER)
  isActive    Boolean  @default(true)
  isOnline    Boolean  @default(false)

  // Suspension Logic
  suspensionStatus         SuspensionStatus @default(NONE)
  isSuspended              Boolean          @default(false)
  suspensionReviewDeadline DateTime?
  suspensionLevel          Int              @default(0)
  suspensionReason         String?
  suspendedBy              String?
  suspendedAt              DateTime?

  // Location Data
  state           String?
  district        String?
  latitude        Float?
  longitude       Float?
  serviceRadiusKm Int     @default(10)

  // Relations
  wallet           Wallet?
  applications     Application[]           @relation("CustomerApplications")
  assignedApps     Application[]           @relation("AgentApplications")
  appAssignments   ApplicationAssignment[]
  agentServices    AgentService[] // Capabilities mapping
  transactions     Transaction[]
  escrowAsCustomer EscrowHolding[]         @relation("EscrowCustomer")
  escrowAsAgent    EscrowHolding[]         @relation("EscrowAgent")

  withdrawals         WithdrawalRequest[] @relation("AgentWithdrawals")
  approvedWithdrawals WithdrawalRequest[] @relation("ApprovedWithdrawals")
  rejectedWithdrawals WithdrawalRequest[] @relation("RejectedWithdrawals")

  agentMetrics  AgentMetrics?
  notifications Notification[]

  ticketsCreated  Ticket[]         @relation("CreatedTickets")
  ticketsAssigned Ticket[]         @relation("AssignedTickets")
  ticketResponses TicketResponse[]

  auditLogs AuditLog[]

  initiatedSuspensions SuspensionCase[] @relation("SuspensionInitiator")
  suspensionCases      SuspensionCase[] @relation("UserSuspensions")
  escalatedCases       SuspensionCase[] @relation("EscalatedTo")
  resolvedCases        SuspensionCase[] @relation("ResolvedBy")

  refundRequests  RefundRequest[] @relation("RefundRequester")
  reviewedRefunds RefundRequest[] @relation("RefundReviewer")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([state])
  @@index([district])
}

///////////////////////////////////////////////////////
// FINANCIALS
///////////////////////////////////////////////////////

model Wallet {
  id       String  @id @default(uuid())
  balance  Decimal @default(0.0) @db.Decimal(12, 2)
  isFrozen Boolean @default(false)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  withdrawals  WithdrawalRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id             String   @id @default(uuid())
  idempotencyKey String?  @unique
  amount         Decimal  @db.Decimal(12, 2)
  balanceBefore  Decimal? @db.Decimal(12, 2)
  balanceAfter   Decimal? @db.Decimal(12, 2)

  type   TransactionType
  status TransactionStatus @default(PENDING)

  gatewayOrderId   String?
  gatewayPaymentId String?
  referenceId      String?
  metadata         Json?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  walletId String?
  wallet   Wallet? @relation(fields: [walletId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([referenceId])
  @@index([walletId])
}

///////////////////////////////////////////////////////
// APPLICATION & ASSIGNMENT
///////////////////////////////////////////////////////

model Application {
  id          String @id @default(uuid())
  state       String
  district    String
  serviceType String

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  mode   ServiceMode
  status ApplicationStatus @default(DRAFT)

  govtFee            Decimal @db.Decimal(12, 2)
  serviceFee         Decimal @db.Decimal(12, 2)
  platformCommission Decimal @db.Decimal(12, 2)
  agentCommission    Decimal @db.Decimal(12, 2)
  deliveryFee        Decimal @default(0.0) @db.Decimal(12, 2)
  totalAmount        Decimal @db.Decimal(12, 2)

  pricingSnapshot Json?

  paymentStatus TransactionStatus @default(PENDING)
  paidAt        DateTime?

  refundRequested Boolean @default(false)

  riskScore Int @default(0)

  documents      ApplicationDocument[]
  escrow         EscrowHolding?
  refundRequests RefundRequest[]
  history        ApplicationLog[]
  assignments    ApplicationAssignment[]

  customerId String
  customer   User   @relation("CustomerApplications", fields: [customerId], references: [id], onDelete: Cascade)

  agentId String?
  agent   User?   @relation("AgentApplications", fields: [agentId], references: [id])

  assignmentDeadline DateTime?
  assignedAt         DateTime?
  completedAt        DateTime?
  acceptedAt      DateTime?
  manualReview    Boolean   @default(false)
  escalationLevel Int       @default(0)


  deliveryAddress String?
  customerLat     Float?
  customerLng     Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([agentId])
  @@index([status])
  @@index([serviceId])
}

model ApplicationAssignment {
  id String @id @default(uuid())

  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  agentId String
  agent   User   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  status AssignmentStatus @default(PENDING)

  assignedAt  DateTime  @default(now())
  respondedAt DateTime?

  responseReason String?
  priorityScore  Float?

  createdAt DateTime @default(now())

  @@unique([applicationId, agentId])
  @@index([applicationId])
  @@index([agentId])
  @@index([status])
}

model ApplicationDocument {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  name     String
  fileUrl  String
  status   DocumentStatus @default(PENDING)
  feedback String?

  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([applicationId])
}

model ApplicationLog {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  fromStatus ApplicationStatus
  toStatus   ApplicationStatus
  note       String?
  updatedBy  String?

  createdAt DateTime @default(now())
}

///////////////////////////////////////////////////////
// SERVICES & PRICING
///////////////////////////////////////////////////////

model Service {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?
  isActive    Boolean @default(true)

  stateId String
  state   State  @relation(fields: [stateId], references: [id], onDelete: Cascade)

  pricingRules      PricingRule[]
  documents         ServiceRequiredDocument[]
  applications      Application[]
  agentCapabilities AgentService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentService {
  id        String  @id @default(uuid())
  agentId   String
  agent     User    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  isActive  Boolean @default(true)

  @@unique([agentId, serviceId])
}

model PricingRule {
  id        String  @id @default(uuid())
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  mode       ServiceMode
  minGovtFee Decimal     @db.Decimal(12, 2)
  maxGovtFee Decimal     @db.Decimal(12, 2)
  multiplier Float

  serviceFee         Decimal? @db.Decimal(12, 2)
  platformCommission Decimal? @db.Decimal(12, 2)
  agentCommission    Decimal? @db.Decimal(12, 2)

  isActive Boolean @default(true)

  @@index([serviceId])
}

model ServiceRequiredDocument {
  id           String  @id @default(uuid())
  documentName String
  isMandatory  Boolean @default(true)
  order        Int     @default(0)

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

///////////////////////////////////////////////////////
// METRICS, WITHDRAWALS & REFUNDS
///////////////////////////////////////////////////////

model AgentMetrics {
  id      String @id @default(uuid())
  agentId String @unique
  agent   User   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  activeCases    Int @default(0)
  completedCases Int @default(0)
  rejectionCount Int @default(0)
  timeoutCount   Int @default(0)

  rating        Float @default(5.0)
  priorityScore Float @default(0)

  updatedAt DateTime @updatedAt
}

model WithdrawalRequest {
  id       String           @id @default(uuid())
  agentId  String
  walletId String
  amount   Decimal          @db.Decimal(12, 2)
  status   WithdrawalStatus

  approvedBy      String?
  rejectedBy      String?
  rejectionReason String?

  approvedAt DateTime?
  rejectedAt DateTime?

  createdAt DateTime @default(now())

  agent    User   @relation("AgentWithdrawals", fields: [agentId], references: [id], onDelete: Cascade)
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  approver User?  @relation("ApprovedWithdrawals", fields: [approvedBy], references: [id])
  rejector User?  @relation("RejectedWithdrawals", fields: [rejectedBy], references: [id])

  @@index([agentId])
}

model EscrowHolding {
  id            String      @id @default(uuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  customerId    String
  customer      User        @relation("EscrowCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  agentId       String?
  agent         User?       @relation("EscrowAgent", fields: [agentId], references: [id])

  totalAmount    Decimal   @db.Decimal(12, 2)
  platformAmount Decimal   @db.Decimal(12, 2)
  agentAmount    Decimal   @db.Decimal(12, 2)
  isReleased     Boolean   @default(false)
  releasedAt     DateTime?

  createdAt DateTime @default(now())

  @@index([customerId])
}

model RefundRequest {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User        @relation("RefundRequester", fields: [requestedById], references: [id])
  reviewedById  String?
  reviewedBy    User?       @relation("RefundReviewer", fields: [reviewedById], references: [id])

  amount      Decimal      @db.Decimal(12, 2)
  reason      String
  status      RefundStatus @default(REQUESTED)
  processedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([applicationId])
}

///////////////////////////////////////////////////////
// SUPPORT & GEOGRAPHY
///////////////////////////////////////////////////////

model Ticket {
  id           String           @id @default(uuid())
  title        String
  description  String
  status       TicketStatus     @default(OPEN)
  priority     TicketPriority   @default(MEDIUM)
  category     TicketCategory
  createdById  String
  createdBy    User             @relation("CreatedTickets", fields: [createdById], references: [id], onDelete: Cascade)
  assignedToId String?
  assignedTo   User?            @relation("AssignedTickets", fields: [assignedToId], references: [id])
  responses    TicketResponse[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([createdById])
}

model TicketResponse {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  createdAt DateTime @default(now())

  @@index([ticketId])
}

model State {
  id        String    @id @default(uuid())
  name      String
  code      String    @unique
  isActive  Boolean   @default(true)
  services  Service[]
  pincodes  Pincode[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Pincode {
  id        String   @id @default(uuid())
  code      String   @unique
  district  String
  stateId   String
  state     State    @relation(fields: [stateId], references: [id], onDelete: Cascade)
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())

  @@index([code])
  @@index([stateId])
}

///////////////////////////////////////////////////////
// SYSTEM MODELS
///////////////////////////////////////////////////////

model Otp {
  id        String   @id @default(uuid())
  mobile    String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([mobile])
}

model SuspensionCase {
  id            String           @id @default(uuid())
  userId        String
  user          User             @relation("UserSuspensions", fields: [userId], references: [id], onDelete: Cascade)

  initiatedById String
  initiatedBy   User             @relation("SuspensionInitiator", fields: [initiatedById], references: [id])

  status        SuspensionStatus
  level         Int              @default(0)

  reason        String
  evidence      Json?

  appealAt      DateTime?
  appealMessage String?

  createdAt     DateTime         @default(now())

  escalatedToId String?
  escalatedTo   User?            @relation("EscalatedTo", fields: [escalatedToId], references: [id])

  resolvedById  String?
  resolvedBy    User?            @relation("ResolvedBy", fields: [resolvedById], references: [id])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
}

model AuditLog {
  id           String      @id @default(uuid())
  userId       String?
  user         User?       @relation(fields: [userId], references: [id])
  action       AuditAction
  resourceType String
  resourceId   String?

  method      String?
  path        String?
  oldData     Json?
  newData     Json?
  ip          String?
  userAgent   String?
  requestId   String?
  statusCode  Int?
  success     Boolean? @default(true)

  createdAt    DateTime    @default(now())
}

model PaymentWebhookEvent {
  id        String   @id @default(uuid())
  eventId   String   @unique
  eventType String
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SystemControl {
  id                String   @id @default(uuid())
  paymentsFrozen    Boolean  @default(false)
  withdrawalsFrozen Boolean  @default(false)
  refundsFrozen     Boolean  @default(false)
  updatedAt         DateTime @updatedAt
}
